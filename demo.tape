# peasy-compress-rs — ZIP, TAR, gzip compression (Rust)
# Theme: Catppuccin Mocha
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "Catppuccin Mocha"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-compress-rs — ZIP, TAR, gzip compression for Rust"
Enter
Type "# peasytools.com"
Enter
Sleep 500ms

# Run the demo
Type "cargo run --example demo 2>/dev/null"
Enter
Sleep 5s
